/* === 设计系统变量 === */
page {
  --primary: #FF6B35;
  --primary-light: #FF8F5E;
  --primary-bg: #FFF8F0;
  --bg: #F6F6F6;
  --bg-gray: #F5F5F5;
  --bg-white: #FFFFFF;
  --text: #1A1A1A;
  --text-secondary: #666666;
  --text-light: #999999;
  --text-white: #FFFFFF;
  --price: #FF4D4F;
  --success: #52C41A;
  --warning: #FF9500;
  --card-bg: #FFFFFF;
  --divider: #F0F0F0;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 24rpx rgba(0,0,0,0.08);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* === 通用布局 === */
.container { padding: var(--space-md); }
.page { min-height: 100vh; background: var(--bg); }

.card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-sm);
}

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }

/* === 价格 === */
.price { color: var(--price); font-weight: bold; font-size: 32rpx; }
.price-symbol { font-size: 24rpx; }
.price-original { color: var(--text-light); font-size: 22rpx; text-decoration: line-through; margin-left: 8rpx; }

/* === 标签 === */
.tag { display: inline-block; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-right: 8rpx; font-weight: 500; }
.tag-hot { background: #FFF0E6; color: var(--primary); }
.tag-new { background: #E6F7FF; color: #1890FF; }
.tag-spicy { background: #FFF1F0; color: var(--price); }

/* === 按钮 === */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: var(--text-white);
  border: none;
  border-radius: 44rpx;
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: opacity 0.2s, transform 0.1s;
}
.btn-primary:active { opacity: 0.85; transform: scale(0.98); }
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 44rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  transition: background 0.2s;
}
.btn-outline:active { background: var(--primary-bg); }
.btn-outline::after { border: none; }

.btn-disabled {
  background: #CCCCCC;
  color: var(--text-white);
  border-radius: 44rpx;
  padding: 22rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
  pointer-events: none;
}

/* === 加减按钮 === */
.stepper { display: flex; align-items: center; }
.stepper-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: transform 0.15s;
}
.stepper-btn:active { transform: scale(0.9); }
.stepper-btn-minus { background: var(--bg-gray); color: var(--text-secondary); border: 2rpx solid var(--divider); }
.stepper-btn-plus { background: var(--primary); color: var(--text-white); }
.stepper-num { width: 56rpx; text-align: center; font-size: 28rpx; font-weight: 600; color: var(--text); }

/* === 骨架屏 === */
.skeleton { background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%); background-size: 400% 100%; animation: skeleton-shine 1.5s ease infinite; border-radius: var(--radius-sm); }
.skeleton-text { height: 28rpx; margin-bottom: 16rpx; }
.skeleton-text-sm { height: 22rpx; width: 60%; margin-bottom: 12rpx; }
.skeleton-rect { width: 200rpx; height: 200rpx; border-radius: var(--radius-md); }
.skeleton-circle { width: 80rpx; height: 80rpx; border-radius: 50%; }
@keyframes skeleton-shine { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

/* === Loading 动画 === */
.loading-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid var(--divider); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* === 空状态 === */
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; opacity: 0.8; }
.empty-text { color: var(--text-secondary); font-size: 28rpx; margin-bottom: 8rpx; }
.empty-hint { color: var(--text-light); font-size: 24rpx; margin-bottom: 32rpx; }

/* === 分割线 === */
.divider { height: 1rpx; background: var(--divider); margin: var(--space-sm) 0; }

/* === 角标 === */
.badge {
  position: absolute; top: -8rpx; right: -8rpx;
  min-width: 32rpx; height: 32rpx;
  background: var(--price); color: var(--text-white);
  font-size: 20rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx;
}

/* === 底部安全区 === */
.safe-bottom { padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom)); }

/* === 卡片标题 === */
.card-title { font-size: 30rpx; font-weight: 600; color: var(--text); margin-bottom: var(--space-sm); display: block; }

/* === 摘要行 === */
.summary-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; color: var(--text); }
.summary-row .label { color: var(--text-secondary); }

/* === 页面进入动画 === */
.fade-in { animation: fadeIn 0.3s ease-out; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(16rpx); } to { opacity: 1; transform: translateY(0); } }

/* === 加购动画 === */
.bounce { animation: bounce 0.3s ease; }
@keyframes bounce { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
