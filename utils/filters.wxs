/**
 * WXS 过滤器 — 在 wxml 中直接调用，不走 setData，性能更好
 */

/**
 * 格式化价格：数字 → ¥xx.xx
 */
function formatPrice(price) {
  return '¥' + (price || 0).toFixed(2)
}

/**
 * 格式化价格（不带符号）
 */
function priceNum(price) {
  return (price || 0).toFixed(2)
}

/**
 * 计算小计：price * quantity
 */
function itemTotal(price, quantity) {
  return '¥' + ((price || 0) * (quantity || 0)).toFixed(2)
}

/**
 * 截断文本
 */
function truncate(str, len) {
  if (!str) return ''
  return str.length > len ? str.substring(0, len) + '...' : str
}

/**
 * 拼接 addons 显示
 */
function joinAddons(addons) {
  if (!addons || addons.length === 0) return ''
  return '+' + addons.join(',')
}

module.exports = {
  formatPrice: formatPrice,
  priceNum: priceNum,
  itemTotal: itemTotal,
  truncate: truncate,
  joinAddons: joinAddons
}
