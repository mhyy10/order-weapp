.fav-card { display: flex; align-items: center; gap: 20rpx; }
.fav-image {
  width: 140rpx; height: 140rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--bg-gray);
}
.fav-info { flex: 1; min-width: 0; }
.fav-name { font-size: 28rpx; font-weight: 600; display: block; color: var(--text); }
.fav-desc { font-size: 22rpx; color: var(--text-light); display: block; margin: 6rpx 0 10rpx; }
.fav-bottom { display: flex; align-items: center; }

.fav-actions { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.fav-add {
  width: 64rpx; height: 64rpx;
  background: var(--primary);
  color: var(--text-white);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  transition: transform 0.15s;
}
.fav-add:active { transform: scale(0.88); }
.fav-remove { font-size: 20rpx; color: var(--text-light); }
