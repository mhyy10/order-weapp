.page { padding-bottom: 160rpx; }

.dine-types { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.dine-type {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 16rpx; border-radius: var(--radius-md);
  background: var(--bg-gray);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.dine-type.active { background: var(--primary-bg); border-color: var(--primary); }
.dine-icon { font-size: 40rpx; margin-bottom: 6rpx; }
.dine-label { font-size: 24rpx; font-weight: 500; color: var(--text); }

.info-rows { margin-top: 16rpx; }
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid var(--divider);
}
.info-label { font-size: 28rpx; }
.info-input { text-align: right; font-size: 28rpx; flex: 1; }
.people-stepper { display: flex; align-items: center; }

/* 地址选择 */
.address-selected {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.address-info {
  flex: 1;
  min-width: 0;
}

.address-top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.address-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.address-detail-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.address-arrow {
  font-size: 36rpx;
  color: var(--text-light);
  margin-left: 16rpx;
  font-weight: 300;
}

.address-empty {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.address-empty-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.address-empty-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 积分抵扣 */
.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.points-info {
  flex: 1;
}

.points-balance-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.points-rate {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  display: block;
}

.points-input-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0 8rpx;
  border-top: 1rpx solid var(--divider);
  margin-top: 16rpx;
}

.points-input-label {
  font-size: 28rpx;
  color: var(--text);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.points-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 12rpx 20rpx;
  height: 56rpx;
  box-sizing: border-box;
}

.points-max-hint {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 12rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.points-deduction-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.points-deduction-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.points-deduction-amount {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--success);
}

.order-item { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; }
.order-item-left { flex: 1; display: flex; align-items: baseline; gap: 8rpx; }
.order-item-name { font-size: 28rpx; color: var(--text); }
.order-item-spec { font-size: 24rpx; color: var(--text-light); }
.order-item-right { display: flex; align-items: center; gap: 12rpx; }
.order-item-qty { font-size: 24rpx; color: var(--text-light); }
.order-item-price { font-size: 28rpx; font-weight: 600; color: var(--text); }

.summary-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; }
.summary-row .label { color: var(--text-secondary); }
.total-row { padding-top: 16rpx; }
.total-price { font-size: 36rpx; font-weight: 800; color: var(--price); }

.note-input {
  width: 100%; background: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 20rpx; font-size: 26rpx;
  height: 120rpx; box-sizing: border-box;
}

/* 优惠券选择 */
.coupon-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
  transition: background 0.15s;
}
.coupon-item:last-child { border-bottom: none; }
.coupon-item.selected { background: var(--primary-bg); margin: 0 -24rpx; padding: 20rpx 24rpx; border-radius: var(--radius-sm); }
.coupon-item-info { flex: 1; }
.coupon-item-name { font-size: 28rpx; font-weight: 600; color: var(--text); display: block; }
.coupon-item-desc { font-size: 22rpx; color: var(--text-light); margin-top: 4rpx; display: block; }
.coupon-item-right { display: flex; align-items: center; gap: 16rpx; }
.coupon-item-discount { font-size: 30rpx; font-weight: 800; color: var(--price); }
.coupon-check {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid var(--divider);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: transparent;
  transition: all 0.2s;
}
.coupon-check.checked { background: var(--primary); border-color: var(--primary); color: var(--text-white); }
.no-coupon { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.no-coupon-text { font-size: 26rpx; color: var(--text-light); }
.no-coupon-link { font-size: 26rpx; color: var(--primary); }

.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx;
  background: var(--bg-white);
  box-shadow: var(--shadow-md);
}
.submit-btn { width: 100%; text-align: center; padding: 28rpx 0; }

/* 配送模式样式 */
.info-value { font-size: 28rpx; color: var(--text); font-weight: 500; }
.info-value.free { color: var(--success); }

.delivery-address-row {
  display: flex; align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid var(--divider);
}

.address-empty-inline {
  flex: 1; font-size: 28rpx; color: var(--text-light);
}

.delivery-card { border: 2rpx dashed var(--primary); }

.delivery-fee-hint { padding: 12rpx 0; }
.fee-hint-text { font-size: 22rpx; color: var(--text-light); }
