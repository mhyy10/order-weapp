<wxs src="../../utils/filters.wxs" module="f" />
<view class="page container fade-in">
  <!-- Dine type -->
  <view class="card">
    <text class="card-title">就餐方式</text>
    <view class="dine-types">
      <view class="dine-type {{dineType === 'dine_in' ? 'active' : ''}}" bindtap="onDineTypeChange" data-type="dine_in">
        <text class="dine-icon">🍽️</text>
        <text class="dine-label">堂食</text>
      </view>
      <view class="dine-type {{dineType === 'takeaway' ? 'active' : ''}}" bindtap="onDineTypeChange" data-type="takeaway">
        <text class="dine-icon">🍱</text>
        <text class="dine-label">外带</text>
      </view>
    </view>

    <view wx:if="{{dineType === 'dine_in'}}" class="info-rows">
      <view class="info-row">
        <text class="info-label">📍 桌号</text>
        <input class="info-input" placeholder="请输入桌号" value="{{tableNo}}" bindinput="e => this.setData({tableNo: e.detail.value})" />
      </view>
      <view class="info-row">
        <text class="info-label">👥 就餐人数</text>
        <view class="people-stepper">
          <view class="stepper-btn stepper-btn-minus" bindtap="onPeopleChange" data-op="minus">-</view>
          <text class="stepper-num">{{peopleCount}} 位</text>
          <view class="stepper-btn stepper-btn-plus" bindtap="onPeopleChange" data-op="add">+</view>
        </view>
      </view>
    </view>
  </view>

  <!-- Order items -->
  <view class="card">
    <text class="card-title">已选菜品</text>
    <view wx:for="{{cartItems}}" wx:key="cartKey" class="order-item">
      <view class="order-item-left">
        <text class="order-item-name">{{item.name}}</text>
        <text class="order-item-spec" wx:if="{{item.spec}}">({{item.spec}})</text>
      </view>
      <view class="order-item-right">
        <text class="order-item-qty">×{{item.quantity}}</text>
        <text class="order-item-price">{{f.itemTotal(item.price, item.quantity)}}</text>
      </view>
    </view>

    <view class="divider"></view>
    <view class="summary-row">
      <text class="label">小计</text>
      <text>¥{{subtotal}}</text>
    </view>
    <view class="summary-row" wx:if="{{discount > 0}}">
      <text class="label" style="color:var(--success);">新客立减</text>
      <text style="color:var(--success);">-¥{{discount}}</text>
    </view>
    <view class="summary-row" wx:if="{{dineType === 'dine_in'}}">
      <text class="label">餐位费</text>
      <text>¥3/位 × {{peopleCount}}</text>
    </view>
    <view class="divider"></view>
    <view class="summary-row total-row">
      <text style="font-weight:600;">合计</text>
      <text class="total-price">¥{{total}}</text>
    </view>
  </view>

  <!-- Note -->
  <view class="card">
    <text class="card-title">备注</text>
    <textarea class="note-input" placeholder="请输入备注，如：少放辣、不要香菜..." maxlength="100" value="{{note}}" bindinput="onNoteInput" />
  </view>

  <!-- Submit -->
  <view class="submit-wrap safe-bottom">
    <view class="btn-primary submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmit">
      {{submitting ? '提交中...' : '提交订单 ¥' + total}}
    </view>
  </view>
</view>
