<wxs src="../../utils/filters.wxs" module="f" />
<view class="page container">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="card fade-in">
      <view class="skeleton skeleton-text" style="width:30%;margin-bottom:20rpx;"></view>
      <view style="display:flex;gap:20rpx;">
        <view class="skeleton" style="flex:1;height:120rpx;border-radius:var(--radius-md);"></view>
        <view class="skeleton" style="flex:1;height:120rpx;border-radius:var(--radius-md);"></view>
      </view>
    </view>
    <view class="card fade-in">
      <view class="skeleton skeleton-text" style="width:30%;margin-bottom:20rpx;"></view>
      <view wx:for="{{[1,2,3]}}" wx:key="*this" style="display:flex;justify-content:space-between;padding:14rpx 0;">
        <view class="skeleton skeleton-text" style="width:40%"></view>
        <view class="skeleton skeleton-text-sm" style="width:20%"></view>
      </view>
    </view>
  </block>

  <!-- 空状态：购物车为空 -->
  <view wx:elif="{{cartItems.length === 0}}" class="empty fade-in">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车为空</text>
    <text class="empty-hint">请先添加菜品再下单</text>
    <navigator url="/pages/index/index" open-type="switchTab" class="btn-primary" style="margin-top:32rpx;">去点餐</navigator>
  </view>

  <!-- 实际内容 -->
  <view wx:else class="fade-in">
    <!-- Dine type -->
    <view class="card">
      <text class="card-title">就餐方式</text>
      <view class="dine-types">
        <view class="dine-type {{dineType === 'dine_in' ? 'active' : ''}}" bindtap="onDineTypeChange" data-type="dine_in">
          <text class="dine-icon">🍽️</text>
          <text class="dine-label">堂食</text>
        </view>
        <view class="dine-type {{dineType === 'takeaway' ? 'active' : ''}}" bindtap="onDineTypeChange" data-type="takeaway">
          <text class="dine-icon">🍱</text>
          <text class="dine-label">外带</text>
        </view>
      </view>

      <view wx:if="{{dineType === 'dine_in'}}" class="info-rows">
        <view class="info-row">
          <text class="info-label">📍 桌号</text>
          <input class="info-input" placeholder="请输入桌号" value="{{tableNo}}" bindinput="e => this.setData({tableNo: e.detail.value})" />
        </view>
        <view class="info-row">
          <text class="info-label">👥 就餐人数</text>
          <view class="people-stepper">
            <view class="stepper-btn stepper-btn-minus" bindtap="onPeopleChange" data-op="minus">-</view>
            <text class="stepper-num">{{peopleCount}} 位</text>
            <view class="stepper-btn stepper-btn-plus" bindtap="onPeopleChange" data-op="add">+</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 配送地址 -->
    <view class="card" wx:if="{{dineType === 'takeaway'}}">
      <text class="card-title">配送地址</text>
      <view wx:if="{{selectedAddress}}" class="address-selected" bindtap="onChooseAddress">
        <view class="address-info">
          <view class="address-top-row">
            <text class="address-name">{{selectedAddress.name}}</text>
            <text class="address-phone">{{selectedAddress.phone}}</text>
          </view>
          <text class="address-detail-text">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}} {{selectedAddress.detail}}</text>
        </view>
        <text class="address-arrow">›</text>
      </view>
      <view wx:else class="address-empty" bindtap="onChooseAddress">
        <text class="address-empty-icon">📍</text>
        <text class="address-empty-text">请选择收货地址</text>
        <text class="address-arrow">›</text>
      </view>
    </view>

    <!-- Order items -->
    <view class="card">
      <text class="card-title">已选菜品</text>
      <view wx:for="{{cartItems}}" wx:key="cartKey" class="order-item">
        <view class="order-item-left">
          <text class="order-item-name">{{item.name}}</text>
          <text class="order-item-spec" wx:if="{{item.spec}}">({{item.spec}})</text>
        </view>
        <view class="order-item-right">
          <text class="order-item-qty">×{{item.quantity}}</text>
          <text class="order-item-price">{{f.itemTotal(item.price, item.quantity)}}</text>
        </view>
      </view>

      <view class="divider"></view>
      <view class="summary-row">
        <text class="label">小计</text>
        <text>¥{{subtotal}}</text>
      </view>
      <view class="summary-row" wx:if="{{discount > 0}}">
        <text class="label" style="color:var(--success);">新客立减</text>
        <text style="color:var(--success);">-¥{{discount}}</text>
      </view>
      <view class="summary-row" wx:if="{{couponDiscount > 0}}">
        <text class="label" style="color:var(--success);">优惠券</text>
        <text style="color:var(--success);">-¥{{couponDiscount}}</text>
      </view>
      <view class="summary-row" wx:if="{{pointsDeduction > 0}}">
        <text class="label" style="color:var(--success);">积分抵扣</text>
        <text style="color:var(--success);">-¥{{pointsDeduction}}</text>
      </view>
      <view class="summary-row" wx:if="{{dineType === 'dine_in'}}">
        <text class="label">餐位费</text>
        <text>¥3/位 × {{peopleCount}}</text>
      </view>
      <view class="divider"></view>
      <view class="summary-row total-row">
        <text style="font-weight:600;">合计</text>
        <text class="total-price">¥{{total}}</text>
      </view>
    </view>

    <!-- Coupon -->
    <view class="card" wx:if="{{availableCoupons.length > 0}}">
      <text class="card-title">优惠券</text>
      <view wx:for="{{availableCoupons}}" wx:key="userCouponId" class="coupon-item {{selectedCoupon.userCouponId === item.userCouponId ? 'selected' : ''}}" bindtap="onSelectCoupon" data-idx="{{index}}">
        <view class="coupon-item-info">
          <text class="coupon-item-name">{{item.couponName}}</text>
          <text class="coupon-item-desc">{{item.couponType === 'reduction' ? '满减券' : '折扣券'}}</text>
        </view>
        <view class="coupon-item-right">
          <text class="coupon-item-discount">-¥{{item.discount}}</text>
          <view class="coupon-check {{selectedCoupon.userCouponId === item.userCouponId ? 'checked' : ''}}">
            <text wx:if="{{selectedCoupon.userCouponId === item.userCouponId}}">✓</text>
          </view>
        </view>
      </view>
      <view wx:if="{{availableCoupons.length === 0}}" class="no-coupon">
        <text class="no-coupon-text">暂无可用优惠券</text>
        <navigator url="/pages/coupon/coupon" class="no-coupon-link">去领券</navigator>
      </view>
    </view>

    <!-- 积分抵扣 -->
    <view class="card" wx:if="{{pointsBalance > 0}}">
      <text class="card-title">积分抵扣</text>
      <view class="points-row">
        <view class="points-info">
          <text class="points-balance-text">可用积分：{{pointsBalance}}</text>
          <text class="points-rate">100积分=1元</text>
        </view>
        <switch checked="{{usePoints}}" bindchange="onUsePointsChange" color="var(--primary)" />
      </view>
      <view wx:if="{{usePoints}}" class="points-input-row">
        <text class="points-input-label">使用积分</text>
        <input class="points-input" type="number" placeholder="0" value="{{pointsToUse}}" bindinput="onPointsInput" />
        <text class="points-max-hint">最多{{maxPoints}}积分（抵¥{{maxPointsDeduction}}）</text>
      </view>
      <view wx:if="{{usePoints && pointsDeduction > 0}}" class="points-deduction-row">
        <text class="points-deduction-label">可抵扣</text>
        <text class="points-deduction-amount">¥{{pointsDeduction}}</text>
      </view>
    </view>

    <!-- Note -->
    <view class="card">
      <text class="card-title">备注</text>
      <textarea class="note-input" placeholder="请输入备注，如：少放辣、不要香菜..." maxlength="100" value="{{note}}" bindinput="onNoteInput" />
    </view>

    <!-- Submit -->
    <view class="submit-wrap safe-bottom">
      <view class="btn-primary submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmit">
        {{submitting ? '提交中...' : '提交订单 ¥' + total}}
      </view>
    </view>
  </view>
</view>
