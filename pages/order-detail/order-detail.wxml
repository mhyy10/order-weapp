<wxs src="../../utils/filters.wxs" module="f" />
<view class="page container">
  <view wx:if="{{loading}}" class="flex-center" style="padding:120rpx 0;">
    <view class="loading-spinner"></view>
  </view>
  <view wx:elif="{{order}}" class="fade-in">
    <!-- Status -->
    <view class="status-card card">
      <view class="status-icon-wrap" style="background:{{order.statusColor}}18;">
        <text class="status-icon" style="color:{{order.statusColor}};">{{order.status === 'completed' ? '✓' : order.status === 'cancelled' ? '✗' : '◎'}}</text>
      </view>
      <text class="status-text" style="color:{{order.statusColor}}">{{order.statusText}}</text>
      <text class="status-order-id">订单号: {{order.id}}</text>
      <text class="status-time">{{order.timeStr}}</text>
    </view>

    <!-- Items -->
    <view class="card">
      <text class="card-title">菜品详情</text>
      <view wx:for="{{order.items}}" wx:key="cartKey" class="detail-item">
        <view class="detail-item-info">
          <text class="detail-item-name">{{item.name}}</text>
          <view class="detail-item-tags">
            <text class="detail-item-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
            <text class="detail-item-addons" wx:if="{{item.addons.length > 0}}">{{f.joinAddons(item.addons)}}</text>
          </view>
        </view>
        <view class="detail-item-right">
          <text class="detail-item-qty">×{{item.quantity}}</text>
          <text class="detail-item-price">{{f.itemTotal(item.price, item.quantity)}}</text>
        </view>
      </view>
    </view>

    <!-- Summary -->
    <view class="card">
      <view class="summary-row"><text class="label">桌号</text><text>{{order.tableNo || '-'}}</text></view>
      <view class="summary-row"><text class="label">就餐方式</text><text>{{order.dineType === 'dine_in' ? '堂食' : '外带'}}</text></view>
      <view class="summary-row" wx:if="{{order.note}}"><text class="label">备注</text><text>{{order.note}}</text></view>
      <view class="divider"></view>
      <view class="summary-row"><text class="label">小计</text><text>¥{{order.subtotal}}</text></view>
      <view class="summary-row" wx:if="{{order.discount > 0}}"><text class="label">优惠</text><text style="color:var(--success);">-¥{{order.discount}}</text></view>
      <view class="summary-row" wx:if="{{order.couponDiscount > 0}}"><text class="label">优惠券</text><text style="color:var(--success);">-¥{{order.couponDiscount}}</text></view>
      <view class="divider"></view>
      <view class="summary-row total"><text style="font-weight:600;">合计</text><text class="total-price">¥{{order.total}}</text></view>
    </view>

    <!-- Actions -->
    <view class="actions">
      <view wx:if="{{order.status === 'pending'}}" class="btn-outline action-btn" bindtap="onCancel">取消订单</view>
      <view wx:if="{{order.status === 'confirmed'}}" class="btn-outline action-btn" style="border-color:var(--primary);color:var(--primary);">制作中，请稍候</view>
      <view wx:if="{{order.status === 'ready'}}" class="btn-primary action-btn" bindtap="onConfirmPickup">确认取餐</view>
      <view wx:if="{{order.status === 'completed'}}" class="btn-primary action-btn" bindtap="onReview">📝 评价</view>
      <view wx:if="{{order.status === 'completed' || order.status === 'cancelled'}}" class="btn-outline action-btn" bindtap="onReorder">再来一单</view>
    </view>
  </view>
</view>
