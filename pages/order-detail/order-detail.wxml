<wxs src="../../utils/filters.wxs" module="f" />
<view class="page container">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="status-card card fade-in" style="text-align:center;">
      <view class="skeleton" style="width:96rpx;height:96rpx;border-radius:50%;margin:0 auto 16rpx;"></view>
      <view class="skeleton skeleton-text" style="width:30%;margin:0 auto 12rpx;"></view>
      <view class="skeleton skeleton-text-sm" style="width:50%;margin:0 auto 6rpx;"></view>
      <view class="skeleton skeleton-text-sm" style="width:40%;margin:0 auto;"></view>
    </view>
    <view class="card fade-in">
      <view class="skeleton skeleton-text" style="width:25%;margin-bottom:16rpx;"></view>
      <view wx:for="{{[1,2,3]}}" wx:key="*this" style="display:flex;justify-content:space-between;align-items:center;padding:14rpx 0;border-bottom:1rpx solid var(--divider);">
        <view class="skeleton skeleton-text" style="width:40%"></view>
        <view class="skeleton skeleton-text-sm" style="width:20%"></view>
      </view>
    </view>
  </block>

  <!-- 空状态：订单不存在 -->
  <view wx:elif="{{!order}}" class="empty fade-in">
    <text class="empty-icon">📋</text>
    <text class="empty-text">订单不存在</text>
    <text class="empty-hint">该订单可能已被删除</text>
    <navigator url="/pages/index/index" open-type="switchTab" class="btn-primary" style="margin-top:32rpx;">回首页</navigator>
  </view>

  <!-- 实际内容 -->
  <view wx:elif="{{order}}" class="fade-in">
    <!-- Status -->
    <view class="status-card card">
      <view class="status-icon-wrap" style="background:{{order.statusColor}}18;">
        <text class="status-icon" style="color:{{order.statusColor}};">{{order.status === 'completed' ? '✓' : order.status === 'cancelled' ? '✗' : order.status === 'delivering' ? '🛵' : '◎'}}</text>
      </view>
      <text class="status-text" style="color:{{order.statusColor}}">{{order.statusText}}</text>
      <text class="status-order-id">订单号: {{order.id}}</text>
      <text class="status-time">{{order.timeStr}}</text>
      <!-- 取消原因 -->
      <view wx:if="{{order.cancelReason}}" class="cancel-reason">
        <text class="cancel-reason-text">取消原因：{{order.cancelReason}}</text>
      </view>
      <!-- 配送中额外提示 -->
      <view wx:if="{{order.status === 'delivering' && order.delivery}}" class="delivering-info">
        <text class="delivering-hint">🛵 骑手 {{order.delivery.riderName}} 正在配送中</text>
        <text class="delivering-phone" bindtap="callRider">📞 {{order.delivery.riderPhone}}</text>
      </view>
    </view>

    <!-- 订单时间线 -->
    <view class="card" wx:if="{{timeline.length > 0}}">
      <text class="card-title">订单进度</text>
      <view class="timeline">
        <view wx:for="{{timeline}}" wx:key="index" class="timeline-step {{item.completed ? 'completed' : ''}} {{item.current ? 'current' : ''}} {{item.cancelled ? 'cancelled' : ''}}">
          <view class="timeline-dot-wrap">
            <view class="timeline-dot"></view>
            <view wx:if="{{index < timeline.length - 1}}" class="timeline-line"></view>
          </view>
          <view class="timeline-content">
            <text class="timeline-label">{{item.label}}</text>
            <text wx:if="{{item.timeStr}}" class="timeline-time">{{item.timeStr}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Items -->
    <view class="card">
      <text class="card-title">菜品详情</text>
      <view wx:for="{{order.items}}" wx:key="cartKey" class="detail-item">
        <view class="detail-item-info">
          <text class="detail-item-name">{{item.name}}</text>
          <view class="detail-item-tags">
            <text class="detail-item-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
            <text class="detail-item-addons" wx:if="{{item.addons.length > 0}}">{{f.joinAddons(item.addons)}}</text>
          </view>
        </view>
        <view class="detail-item-right">
          <text class="detail-item-qty">×{{item.quantity}}</text>
          <text class="detail-item-price">{{f.itemTotal(item.price, item.quantity)}}</text>
        </view>
      </view>
    </view>

    <!-- 配送地址（配送订单） -->
    <view class="card" wx:if="{{order.dineType === 'delivery' && order.address}}">
      <text class="card-title">配送信息</text>
      <view class="delivery-address-info">
        <view class="addr-row">
          <text class="addr-label">📍 收货地址</text>
        </view>
        <view class="addr-detail">
          <text class="addr-name">{{order.address.name}}</text>
          <text class="addr-phone">{{order.address.phone}}</text>
        </view>
        <text class="addr-full">{{order.address.province}}{{order.address.city}}{{order.address.district}} {{order.address.detail}}</text>
      </view>
    </view>

    <!-- Summary -->
    <view class="card">
      <view class="summary-row"><text class="label">就餐方式</text><text>{{order.dineTypeText}}</text></view>
      <view class="summary-row" wx:if="{{order.dineType === 'dine_in'}}"><text class="label">桌号</text><text>{{order.tableNo || '-'}}</text></view>
      <view class="summary-row" wx:if="{{order.dineType === 'dine_in'}}"><text class="label">人数</text><text>{{order.peopleCount}} 位</text></view>
      <view class="summary-row" wx:if="{{order.note}}"><text class="label">备注</text><text>{{order.note}}</text></view>
      <view class="divider"></view>
      <view class="summary-row"><text class="label">小计</text><text>¥{{order.subtotal}}</text></view>
      <view class="summary-row" wx:if="{{order.discount > 0}}"><text class="label">优惠</text><text style="color:var(--success);">-¥{{order.discount}}</text></view>
      <view class="summary-row" wx:if="{{order.couponDiscount > 0}}"><text class="label">优惠券</text><text style="color:var(--success);">-¥{{order.couponDiscount}}</text></view>
      <view class="summary-row" wx:if="{{order.pointsDiscount > 0}}"><text class="label">积分抵扣</text><text style="color:var(--success);">-¥{{order.pointsDiscount}}</text></view>
      <view class="summary-row" wx:if="{{order.deliveryFee > 0}}"><text class="label">配送费</text><text>¥{{order.deliveryFee}}</text></view>
      <view class="summary-row" wx:if="{{order.dineType === 'delivery' && order.deliveryFee === 0}}"><text class="label">配送费</text><text style="color:var(--success);">免配送费</text></view>
      <view class="summary-row" wx:if="{{order.dineType === 'dine_in'}}"><text class="label">餐位费</text><text>¥{{order.peopleCount * 3}}</text></view>
      <view class="divider"></view>
      <view class="summary-row total"><text style="font-weight:600;">合计</text><text class="total-price">¥{{order.total}}</text></view>
    </view>

    <!-- Actions -->
    <view class="actions">
      <view wx:if="{{order.status === 'pending' || order.status === 'confirmed'}}" class="btn-outline action-btn" bindtap="onCancel">取消订单</view>
      <view wx:if="{{order.status === 'confirmed'}}" class="btn-outline action-btn" style="border-color:var(--primary);color:var(--primary);">制作中，请稍候</view>
      <!-- 堂食/自提：可取餐 -->
      <view wx:if="{{order.status === 'ready' && order.dineType !== 'delivery'}}" class="btn-primary action-btn" bindtap="onConfirmPickup">确认取餐</view>
      <!-- 配送：配送中 -->
      <view wx:if="{{order.status === 'ready' && order.dineType === 'delivery'}}" class="btn-outline action-btn" style="border-color:var(--primary);color:var(--primary);">等待骑手取餐</view>
      <view wx:if="{{order.status === 'delivering'}}" class="btn-primary action-btn" bindtap="onConfirmDelivered">确认收货</view>
      <view wx:if="{{order.status === 'delivering'}}" class="btn-outline action-btn" bindtap="onViewTrack">查看配送追踪</view>
      <view wx:if="{{order.status === 'completed'}}" class="btn-primary action-btn" bindtap="onReview">📝 评价</view>
      <view wx:if="{{order.status === 'completed' || order.status === 'cancelled'}}" class="btn-outline action-btn" bindtap="onReorder">再来一单</view>
    </view>
  </view>
</view>
