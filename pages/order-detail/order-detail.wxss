.status-card { text-align: center; padding: 48rpx 24rpx; }
.status-icon-wrap {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 16rpx;
}
.status-icon { font-size: 48rpx; font-weight: 800; }
.status-text { font-size: 36rpx; font-weight: 800; display: block; margin-bottom: 12rpx; }
.status-order-id { font-size: 24rpx; color: var(--text-secondary); display: block; }
.status-time { font-size: 22rpx; color: var(--text-light); display: block; margin-top: 6rpx; }

/* 取消原因 */
.cancel-reason {
  margin-top: 16rpx; padding: 12rpx 24rpx;
  background: #fff5f5; border-radius: var(--radius-sm);
}
.cancel-reason-text { font-size: 24rpx; color: #e53e3e; }

/* 订单时间线 */
.timeline { padding: 8rpx 0; }

.timeline-step {
  display: flex;
  min-height: 80rpx;
  position: relative;
}

.timeline-step:last-child { min-height: auto; }

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
  position: relative;
}

.timeline-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: var(--divider);
  border: 4rpx solid var(--bg-gray);
  flex-shrink: 0;
  z-index: 1;
  margin-top: 6rpx;
}

.timeline-step.completed .timeline-dot {
  background: var(--success);
  border-color: #e6f7e6;
}

.timeline-step.current .timeline-dot {
  background: var(--primary);
  border-color: var(--primary-bg);
  width: 24rpx; height: 24rpx;
  margin-top: 4rpx;
}

.timeline-step.cancelled .timeline-dot {
  background: #e53e3e;
  border-color: #fff5f5;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: var(--divider);
  margin: 4rpx 0;
}

.timeline-step.completed .timeline-line {
  background: var(--success);
}

.timeline-content {
  flex: 1;
  padding: 0 0 20rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.timeline-label {
  font-size: 28rpx;
  color: var(--text-light);
}

.timeline-step.completed .timeline-label {
  color: var(--text);
}

.timeline-step.current .timeline-label {
  color: var(--primary);
  font-weight: 600;
}

.timeline-step.cancelled .timeline-label {
  color: #e53e3e;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

/* 菜品详情 */
.detail-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.detail-item:last-child { border-bottom: none; }
.detail-item-info { flex: 1; min-width: 0; }
.detail-item-name { font-size: 28rpx; color: var(--text); }
.detail-item-tags { display: flex; gap: 8rpx; margin-top: 4rpx; }
.detail-item-spec, .detail-item-addons {
  font-size: 22rpx; color: var(--text-light);
  background: var(--bg-gray); padding: 2rpx 10rpx; border-radius: 6rpx;
}
.detail-item-right { display: flex; align-items: center; gap: 12rpx; }
.detail-item-qty { font-size: 24rpx; color: var(--text-light); }
.detail-item-price { font-size: 28rpx; font-weight: 600; color: var(--text); }

.summary-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; }
.summary-row .label { color: var(--text-secondary); }
.total { padding-top: 16rpx; }
.total-price { font-size: 36rpx; font-weight: 800; color: var(--price); }

.actions { margin-top: 40rpx; display: flex; gap: 20rpx; }
.action-btn { flex: 1; text-align: center; padding: 24rpx; }

/* 配送信息 */
.delivering-info {
  margin-top: 16rpx; padding-top: 16rpx;
  border-top: 1rpx solid var(--divider);
}
.delivering-hint { font-size: 28rpx; color: var(--primary); display: block; font-weight: 600; }
.delivering-phone { font-size: 24rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }

.delivery-address-info { padding: 8rpx 0; }
.addr-row { margin-bottom: 8rpx; }
.addr-label { font-size: 28rpx; font-weight: 600; color: var(--text); }
.addr-detail { display: flex; align-items: center; gap: 16rpx; margin-bottom: 6rpx; }
.addr-name { font-size: 28rpx; font-weight: 700; color: var(--text); }
.addr-phone { font-size: 26rpx; color: var(--text-secondary); }
.addr-full { font-size: 24rpx; color: var(--text-secondary); line-height: 1.5; }
