.hero { position: relative; width: 100%; height: 500rpx; }
.hero-img { width: 100%; height: 100%; }
.fav-btn {
  position: absolute; top: 24rpx; right: 24rpx;
  width: 80rpx; height: 80rpx;
  background: rgba(0,0,0,0.35);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: #fff;
  backdrop-filter: blur(8rpx);
  transition: transform 0.2s;
}
.fav-btn:active { transform: scale(0.9); }
.fav-btn.active { color: var(--price); }

.info-card { background: var(--bg-white); padding: 28rpx; margin-bottom: 2rpx; }
.info-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx; }
.dish-name { font-size: 38rpx; font-weight: 800; color: var(--text); }
.dish-tags { display: flex; gap: 8rpx; }
.dish-desc { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 10rpx; display: block; line-height: 1.6; }
.dish-meta { font-size: 24rpx; color: var(--text-light); margin-bottom: 20rpx; }
.price-row { display: flex; align-items: baseline; gap: 4rpx; }
.price-symbol { font-size: 28rpx; color: var(--price); font-weight: 700; }
.price-value { font-size: 48rpx; color: var(--price); font-weight: 900; line-height: 1; }
.price-original { color: var(--text-light); text-decoration: line-through; font-size: 26rpx; margin-left: 12rpx; }

.section-label { font-size: 28rpx; font-weight: 700; margin-bottom: 16rpx; display: block; }
.spec-label { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 10rpx; display: block; }
.spec-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.spec-tag {
  font-size: 24rpx; padding: 10rpx 24rpx;
  background: var(--bg-gray); border-radius: 28rpx;
  color: var(--text-secondary);
}

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx;
  background: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.add-btn { width: 100%; text-align: center; padding: 28rpx 0; }

.spec-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 300; opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.spec-overlay.show { opacity: 1; pointer-events: auto; }
.spec-panel {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: var(--bg-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex; flex-direction: column;
}
.spec-overlay.show .spec-panel { transform: translateY(0); }

.spec-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--divider);
}
.spec-title { font-size: 34rpx; font-weight: 700; }
.spec-close { font-size: 48rpx; color: var(--text-light); padding: 8rpx; line-height: 1; }

.spec-body { flex: 1; padding: 24rpx 32rpx; max-height: 45vh; }
.spec-group { margin-bottom: 28rpx; }
.spec-group-title { font-size: 28rpx; font-weight: 700; margin-bottom: 14rpx; display: block; }
.spec-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.spec-option {
  font-size: 26rpx; padding: 14rpx 32rpx;
  border-radius: 32rpx;
  background: var(--bg-gray);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.spec-option.active {
  background: var(--primary-bg);
  border-color: var(--primary);
  color: var(--primary);
  font-weight: 600;
}

.spec-footer { padding: 20rpx 32rpx; }
