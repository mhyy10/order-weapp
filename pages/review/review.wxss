.page { padding-bottom: 160rpx; }

.stars { display: flex; gap: 16rpx; justify-content: center; padding: 16rpx 0; }
.star {
  font-size: 56rpx; color: var(--divider);
  transition: transform 0.15s, color 0.15s;
}
.star.active { color: #FFB800; }
.star:active { transform: scale(1.2); }

.rating-text { display: block; text-align: center; font-size: 28rpx; color: var(--text-secondary); margin-top: 8rpx; }

.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-item {
  font-size: 26rpx; padding: 12rpx 24rpx;
  border-radius: 28rpx;
  background: var(--bg-gray);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.tag-item.active {
  background: var(--primary-bg);
  color: var(--primary);
  border-color: var(--primary);
  font-weight: 600;
}

.review-input {
  width: 100%; background: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 20rpx; font-size: 28rpx;
  height: 200rpx; box-sizing: border-box;
}
.char-count {
  display: block; text-align: right;
  font-size: 22rpx; color: var(--text-light); margin-top: 8rpx;
}

.submit-wrap {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx;
  background: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.submit-btn { width: 100%; text-align: center; padding: 28rpx 0; }
