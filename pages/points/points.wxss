.page { background: var(--bg); min-height: 100vh; }

.points-header {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  padding: 56rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-balance {
  font-size: 80rpx;
  font-weight: 900;
  color: var(--text-white);
  line-height: 1.1;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}

.header-stats {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  background: rgba(255,255,255,0.15);
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-white);
}

.stat-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  padding: 28rpx 32rpx 12rpx;
}

.record-list {
  padding: 0 24rpx;
}

.record-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.icon-earn {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

.icon-spend {
  background: rgba(255, 149, 0, 0.1);
  color: var(--warning);
}

.record-info {
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}

.record-desc {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
  display: block;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 800;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.amount-earn {
  color: var(--success);
}

.amount-spend {
  color: var(--warning);
}

.load-more {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-light);
}
