.user-header {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  padding: 64rpx 32rpx 48rpx;
  display: flex; align-items: center; gap: 24rpx;
}
.avatar-wrap {
  width: 128rpx; height: 128rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.4);
  overflow: hidden;
}
.avatar-img { width: 100%; height: 100%; }
.avatar-text { font-size: 64rpx; }
.user-info { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 800; color: var(--text-white); display: block; }
.user-id { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 6rpx; }

.stats-row {
  display: flex;
  background: var(--bg-white);
  margin: -28rpx 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 28rpx 0;
  box-shadow: var(--shadow-md);
  position: relative; z-index: 1;
}
.stat-item { flex: 1; text-align: center; display: flex; flex-direction: column; }
.stat-item:not(:last-child) { border-right: 1rpx solid var(--divider); }
.stat-num { font-size: 40rpx; font-weight: 800; color: var(--text); }
.stat-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

.scan-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 36rpx;
  margin: 0 24rpx 16rpx;
  background: linear-gradient(135deg, #FFF8F0, #FFFFFF);
  border: 2rpx solid rgba(255,107,53,0.1);
}
.scan-icon-wrap {
  width: 96rpx; height: 96rpx;
  background: var(--primary-bg);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16rpx;
}
.scan-icon { font-size: 48rpx; }
.scan-text { font-size: 30rpx; font-weight: 700; color: var(--text); }
.scan-hint { font-size: 22rpx; color: var(--text-light); margin-top: 6rpx; }

.menu-card { margin: 0 24rpx; }
.menu-item {
  display: flex; align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid var(--divider);
  transition: background 0.15s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--bg-gray); margin: 0 -24rpx; padding: 30rpx 24rpx; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-title { flex: 1; font-size: 28rpx; color: var(--text); }
.menu-arrow { font-size: 32rpx; color: var(--text-light); font-weight: 300; }
