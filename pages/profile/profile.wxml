<wxs src="../../utils/filters.wxs" module="f" />
<view class="page">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="user-header fade-in">
      <view class="avatar-wrap">
        <view class="skeleton" style="width:128rpx;height:128rpx;border-radius:50%;"></view>
      </view>
      <view class="user-info" style="flex:1;">
        <view class="skeleton skeleton-text" style="width:40%;margin-bottom:12rpx;"></view>
        <view class="skeleton skeleton-text-sm" style="width:60%;"></view>
      </view>
    </view>
    <view class="stats-row fade-in">
      <view class="stat-item">
        <view class="skeleton" style="width:60rpx;height:40rpx;margin:0 auto 8rpx;"></view>
        <view class="skeleton skeleton-text-sm" style="width:50rpx;margin:0 auto;"></view>
      </view>
      <view class="stat-item">
        <view class="skeleton" style="width:60rpx;height:40rpx;margin:0 auto 8rpx;"></view>
        <view class="skeleton skeleton-text-sm" style="width:50rpx;margin:0 auto;"></view>
      </view>
      <view class="stat-item">
        <view class="skeleton" style="width:60rpx;height:40rpx;margin:0 auto 8rpx;"></view>
        <view class="skeleton skeleton-text-sm" style="width:50rpx;margin:0 auto;"></view>
      </view>
    </view>
    <view class="card menu-card fade-in" style="margin:16rpx 24rpx;">
      <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" style="display:flex;align-items:center;padding:30rpx 0;border-bottom:1rpx solid var(--divider);">
        <view class="skeleton" style="width:36rpx;height:36rpx;border-radius:8rpx;margin-right:20rpx;"></view>
        <view class="skeleton skeleton-text" style="width:40%;"></view>
      </view>
    </view>
  </block>

  <!-- 空状态：未登录 -->
  <block wx:elif="{{!userInfo}}">
    <view class="user-header">
      <view class="avatar-wrap">
        <text class="avatar-text">🍽️</text>
      </view>
      <view class="user-info">
        <text class="user-name">未登录</text>
        <text class="user-id">请先登录查看个人信息</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">0</text>
        <text class="stat-label">订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">0</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">-</text>
        <text class="stat-label">排队</text>
      </view>
    </view>
    <view class="empty" style="padding:80rpx 48rpx;">
      <text class="empty-icon">👤</text>
      <text class="empty-text">暂无用户信息</text>
      <text class="empty-hint">请先登录后查看</text>
    </view>
  </block>

  <!-- 实际内容 -->
  <block wx:else>
    <!-- User header -->
    <view class="user-header fade-in">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-text">🍽️</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || '美食家'}}</text>
        <text class="user-id">ID: {{userInfo.id || '-'}}</text>
      </view>
    </view>

    <!-- Quick stats -->
    <view class="stats-row fade-in">
      <navigator url="/pages/order-list/order-list" class="stat-item">
        <text class="stat-num">{{orderCount}}</text>
        <text class="stat-label">订单</text>
      </navigator>
      <navigator url="/pages/favorites/favorites" class="stat-item">
        <text class="stat-num">{{favCount}}</text>
        <text class="stat-label">收藏</text>
      </navigator>
      <navigator url="/pages/queue/queue" class="stat-item">
        <text class="stat-num">-</text>
        <text class="stat-label">排队</text>
      </navigator>
    </view>

    <!-- Scan table -->
    <view class="card scan-card" bindtap="onScanTable">
      <view class="scan-icon-wrap">
        <text class="scan-icon">📷</text>
      </view>
      <text class="scan-text">扫码点餐</text>
      <text class="scan-hint">扫描桌上二维码开始点餐</text>
    </view>

    <!-- Menu -->
    <view class="card menu-card">
      <view wx:for="{{menuItems}}" wx:key="title" class="menu-item" bindtap="onMenuTap" data-url="{{item.url}}">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </block>
</view>
