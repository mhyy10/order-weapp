.search-header {
  display: flex; align-items: center;
  background: var(--bg-white);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.search-clear { font-size: 40rpx; color: var(--text-light); padding: 0 8rpx; }

.search-loading {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  padding: 80rpx 0;
}
.search-loading-text { font-size: 28rpx; color: var(--text-secondary); }

.dish-card {
  display: flex; gap: 20rpx;
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: background 0.15s;
}
.dish-card:active { background: var(--bg-gray); }

.dish-image {
  width: 160rpx; height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--bg-gray);
}
.dish-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.dish-name { font-size: 28rpx; font-weight: 600; color: var(--text); display: block; }
.dish-desc {
  font-size: 22rpx; color: var(--text-light); display: block; margin: 6rpx 0;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.dish-bottom { display: flex; justify-content: space-between; align-items: center; }
.price-wrap { display: flex; align-items: baseline; gap: 2rpx; }
.price-symbol { font-size: 22rpx; color: var(--price); font-weight: 600; }
.price-value { font-size: 32rpx; color: var(--price); font-weight: 800; }
.btn-add {
  width: 52rpx; height: 52rpx;
  background: var(--primary); color: var(--text-white);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx; font-weight: 700;
  transition: transform 0.15s;
}
.btn-add:active { transform: scale(0.88); }
