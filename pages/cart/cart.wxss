.cart-item { display: flex; justify-content: space-between; align-items: center; }
.cart-item-info { flex: 1; min-width: 0; }
.cart-item-name { font-size: 28rpx; font-weight: 600; display: block; color: var(--text); }
.cart-item-tags { display: flex; gap: 8rpx; margin-top: 6rpx; }
.cart-item-spec, .cart-item-addons {
  font-size: 22rpx; color: var(--text-light);
  background: var(--bg-gray); padding: 2rpx 10rpx; border-radius: 6rpx;
}
.cart-item-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 32rpx;
  background: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.bottom-total-wrap { display: flex; flex-direction: column; }
.bottom-total-label { font-size: 22rpx; color: var(--text-light); }
.bottom-total { font-size: 36rpx; font-weight: 800; color: var(--price); }
.checkout-btn { padding: 22rpx 48rpx; }
