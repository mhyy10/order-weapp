/* === 点菜首页 === */
.page { height: 100vh; display: flex; flex-direction: column; background: var(--bg); }

/* Header */
.header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 32rpx;
  background: var(--bg-white);
  border-bottom: 1rpx solid var(--divider);
  position: sticky; top: 0; z-index: 50;
}
.header-left { display: flex; align-items: center; gap: 16rpx; }
.brand { font-size: 38rpx; font-weight: 800; color: var(--text); letter-spacing: -1rpx; }
.table-tag {
  background: var(--primary-bg);
  border: 1rpx solid rgba(255,107,53,0.2);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.table-tag-text { font-size: 22rpx; color: var(--primary); font-weight: 500; }
.header-right { display: flex; align-items: center; gap: 16rpx; }
.search-btn {
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-gray);
  border-radius: 50%;
}
.icon-search { font-size: 30rpx; }

/* Main wrap */
.main-wrap { flex: 1; display: flex; overflow: hidden; }

/* Left category sidebar */
.category-sidebar {
  width: 170rpx;
  background: var(--bg-white);
  height: calc(100vh - 120rpx);
}
.category-item {
  display: flex; align-items: center; justify-content: center;
  padding: 30rpx 16rpx;
  position: relative;
  transition: all 0.2s ease;
}
.category-item.active { background: var(--bg); }
.category-item.active::before {
  content: '';
  position: absolute; left: 0; top: 50%; transform: translateY(-50%);
  width: 6rpx; height: 40rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
}
.category-name {
  font-size: 26rpx; color: var(--text-secondary);
  text-align: center; line-height: 1.3;
}
.category-item.active .category-name {
  color: var(--primary); font-weight: 600;
}

/* Right dish list */
.dish-list-wrap {
  flex: 1;
  height: calc(100vh - 120rpx);
  background: var(--bg);
}

.section-title {
  display: flex; align-items: baseline; gap: 8rpx;
  padding: 32rpx 24rpx 16rpx;
  background: var(--bg);
}
.section-name { font-size: 30rpx; font-weight: 700; color: var(--text); }
.section-count { font-size: 22rpx; color: var(--text-light); }

/* Dish card */
.dish-card {
  display: flex;
  padding: 24rpx;
  background: var(--bg-white);
  margin: 0 0 2rpx;
  gap: 24rpx;
  transition: background 0.15s;
}
.dish-card:active { background: var(--bg-gray); }

.dish-image {
  width: 200rpx; height: 200rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--bg-gray);
}
.dish-info {
  flex: 1; display: flex; flex-direction: column;
  justify-content: space-between;
  min-width: 0; padding: 2rpx 0;
}
.dish-header { margin-bottom: 6rpx; }
.dish-name {
  font-size: 30rpx; font-weight: 600; color: var(--text);
  display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.dish-tags { display: flex; gap: 6rpx; margin-top: 6rpx; }
.dish-desc {
  font-size: 24rpx; color: var(--text-light);
  line-height: 1.4;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.dish-meta { margin-top: 4rpx; }
.dish-sales { font-size: 22rpx; color: var(--text-light); }

.dish-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 12rpx;
}
.price-wrap { display: flex; align-items: baseline; gap: 2rpx; }
.price-symbol { font-size: 24rpx; color: var(--price); font-weight: 600; }
.price-value { font-size: 38rpx; color: var(--price); font-weight: 800; line-height: 1; }
.price-original {
  color: var(--text-light); font-size: 22rpx;
  text-decoration: line-through; margin-left: 8rpx;
}

.dish-actions { display: flex; align-items: center; }
.btn-spec {
  font-size: 24rpx; color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 28rpx;
  padding: 10rpx 24rpx; font-weight: 500;
  transition: background 0.15s;
}
.btn-spec:active { background: var(--primary-bg); }

.stepper { display: flex; align-items: center; }
.stepper-btn {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
  transition: transform 0.15s;
}
.stepper-btn:active { transform: scale(0.88); }
.stepper-btn-minus { background: var(--bg-gray); color: var(--text-secondary); }
.stepper-btn-plus { background: var(--primary); color: var(--text-white); }
.stepper-num {
  width: 52rpx; text-align: center;
  font-size: 28rpx; font-weight: 600; color: var(--text);
}

/* Cart bar */
.cart-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  background: #1F1F1F;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.cart-bar.show { transform: translateY(0); }

.cart-bar-left { display: flex; align-items: center; gap: 20rpx; }
.cart-icon-wrap {
  position: relative;
  width: 80rpx; height: 80rpx;
  background: #333; border: 4rpx solid #444;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-top: -28rpx;
}
.cart-icon { font-size: 38rpx; }
.cart-badge {
  position: absolute; top: -4rpx; right: -4rpx;
  min-width: 32rpx; height: 32rpx;
  background: var(--price); color: var(--text-white);
  font-size: 20rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #1F1F1F;
}
.cart-price-wrap { display: flex; flex-direction: column; }
.cart-total-label { font-size: 20rpx; color: rgba(255,255,255,0.5); }
.cart-total { color: var(--text-white); font-size: 38rpx; font-weight: 800; line-height: 1.1; }

.cart-bar-btn {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: var(--text-white);
  font-size: 28rpx; font-weight: 700;
  padding: 22rpx 48rpx;
  border-radius: 40rpx;
  transition: opacity 0.15s;
}
.cart-bar-btn:active { opacity: 0.85; }

/* Cart overlay */
.cart-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.cart-overlay.show { opacity: 1; pointer-events: auto; }

.cart-panel {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: var(--bg-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 65vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.cart-overlay.show .cart-panel { transform: translateY(0); }

.cart-panel-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--divider);
}
.cart-panel-title { font-size: 32rpx; font-weight: 700; color: var(--text); }
.cart-clear { font-size: 26rpx; color: var(--text-light); padding: 8rpx; }

.cart-panel-list { max-height: 50vh; padding: 0 32rpx; }
.cart-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}
.cart-item:last-child { border-bottom: none; }
.cart-item-info { flex: 1; min-width: 0; }
.cart-item-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.cart-item-tags { display: flex; gap: 8rpx; margin-top: 4rpx; }
.cart-item-spec, .cart-item-addons {
  font-size: 22rpx; color: var(--text-light);
  background: var(--bg-gray); padding: 2rpx 10rpx; border-radius: 6rpx;
}
.cart-item-right { display: flex; align-items: center; gap: 24rpx; }
.cart-item-price { font-size: 28rpx; font-weight: 700; color: var(--price); }

/* Spec modal */
.spec-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 300;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.spec-overlay.show { opacity: 1; pointer-events: auto; }

.spec-panel {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: var(--bg-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex; flex-direction: column;
}
.spec-overlay.show .spec-panel { transform: translateY(0); }

.spec-header {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--divider);
}
.spec-header-info { flex: 1; }
.spec-dish-name { font-size: 36rpx; font-weight: 800; color: var(--text); display: block; }
.spec-dish-price { font-size: 28rpx; color: var(--price); margin-top: 6rpx; display: block; font-weight: 600; }
.spec-close {
  font-size: 44rpx; color: var(--text-light);
  padding: 8rpx 0 8rpx 16rpx;
  line-height: 1;
}

.spec-body { flex: 1; padding: 24rpx 32rpx; }
.spec-group { margin-bottom: 32rpx; }
.spec-group-title {
  font-size: 28rpx; font-weight: 700; color: var(--text);
  display: block; margin-bottom: 16rpx;
}
.spec-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.spec-option {
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 28rpx;
  border: 2rpx solid var(--divider);
  border-radius: var(--radius-sm);
  font-size: 26rpx; color: var(--text-secondary);
  background: var(--bg-white);
  transition: all 0.15s;
}
.spec-option.active {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-bg);
}
.spec-option-price { font-size: 22rpx; color: var(--text-light); }
.spec-note-input {
  width: 100%; padding: 24rpx;
  border: 2rpx solid var(--divider);
  border-radius: var(--radius-sm);
  font-size: 28rpx; background: var(--bg-gray);
  box-sizing: border-box;
}

.spec-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--divider);
}
.spec-add-btn { width: 100%; text-align: center; padding: 28rpx 0; }
