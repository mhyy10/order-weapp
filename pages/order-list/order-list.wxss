/* Tab 栏 */
.tab-bar {
  display: flex;
  white-space: nowrap;
  background: var(--bg-white);
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--divider);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  position: relative;
  flex-shrink: 0;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--primary);
}

/* 订单卡片 */
.order-card { padding: 24rpx; transition: background 0.15s; }
.order-card:active { background: var(--bg-gray); }

.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.order-header-left { display: flex; align-items: center; gap: 12rpx; }
.order-id { font-size: 24rpx; color: var(--text-light); }
.dine-type-tag {
  font-size: 20rpx; font-weight: 600;
  padding: 2rpx 12rpx; border-radius: 8rpx;
}
.dine-type-dine_in { background: #e3f2fd; color: #1565c0; }
.dine-type-takeaway { background: #fff3e0; color: #e65100; }
.dine-type-delivery { background: #fce4ec; color: #c62828; }
.order-status-tag {
  font-size: 22rpx; font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.order-items-preview {
  font-size: 26rpx; color: var(--text);
  margin-bottom: 12rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.order-more { color: var(--text-light); }

.order-footer { display: flex; justify-content: space-between; align-items: center; }
.order-footer-right { display: flex; align-items: center; gap: 16rpx; }
.order-time { font-size: 22rpx; color: var(--text-light); }
.order-total { font-size: 32rpx; font-weight: 800; color: var(--price); }

.review-tag {
  font-size: 22rpx; font-weight: 600;
  padding: 6rpx 18rpx; border-radius: 20rpx;
  background: var(--primary); color: var(--text-white);
}
.review-tag:active { opacity: 0.85; }
.review-tag.reviewed {
  background: var(--bg-gray); color: var(--text-light);
  font-weight: 400;
}

.cancel-tag {
  font-size: 22rpx; font-weight: 500;
  padding: 6rpx 18rpx; border-radius: 20rpx;
  border: 1rpx solid var(--text-light);
  color: var(--text-light);
}
.cancel-tag:active { opacity: 0.7; }

.load-more {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 32rpx 0;
}
.load-more-text { font-size: 24rpx; color: var(--text-light); }
