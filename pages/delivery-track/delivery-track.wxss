/* 骑手信息卡 */
.rider-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.rider-avatar {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  background: var(--primary-bg);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.rider-avatar.waiting {
  background: #fff3e0;
}

.rider-info {
  flex: 1;
  min-width: 0;
}
.rider-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
}
.rider-status {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
}

.rider-call {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--success);
  border-radius: var(--radius-md);
}
.rider-call:active { opacity: 0.85; }
.call-icon { font-size: 32rpx; }
.call-text { font-size: 22rpx; color: var(--text-white); font-weight: 600; margin-top: 2rpx; }

/* 地图占位 */
.map-card { padding: 24rpx; }
.map-placeholder {
  padding: 40rpx 24rpx;
  background: var(--bg-gray);
  border-radius: var(--radius-md);
  text-align: center;
}

.map-route {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 24rpx;
}

.map-start, .map-rider, .map-end {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.map-dot {
  width: 32rpx; height: 32rpx;
  border-radius: 50%;
  display: block;
}
.map-dot.start { background: var(--primary); }
.map-dot.rider { background: #1890FF; }
.map-dot.end { background: var(--success); }

.map-label { font-size: 22rpx; color: var(--text-secondary); }

.map-line {
  width: 80rpx; height: 4rpx;
  background: var(--primary);
  margin: 0 8rpx;
  margin-bottom: 24rpx;
}
.map-line.dashed {
  background: transparent;
  border-top: 4rpx dashed #ccc;
}

.map-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 地址信息 */
.addr-info { padding: 8rpx 0; }
.addr-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 6rpx; }
.addr-name { font-size: 28rpx; font-weight: 700; color: var(--text); }
.addr-phone { font-size: 26rpx; color: var(--text-secondary); }
.addr-detail { font-size: 24rpx; color: var(--text-secondary); line-height: 1.5; }

/* 时间轴 */
.timeline { padding: 8rpx 0; }

.timeline-item {
  display: flex;
  min-height: 100rpx;
  position: relative;
}
.timeline-item.first { min-height: 80rpx; }

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  background: var(--bg-gray);
  border: 3rpx solid var(--divider);
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx;
  flex-shrink: 0;
  z-index: 1;
}
.timeline-dot.active {
  background: var(--primary);
  border-color: var(--primary);
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: var(--divider);
  margin: 4rpx 0;
}
.timeline-line.active {
  background: var(--primary);
}

.timeline-content {
  flex: 1;
  padding: 6rpx 0 24rpx 16rpx;
}

.timeline-desc {
  font-size: 28rpx;
  color: var(--text-light);
  display: block;
}
.timeline-desc.active {
  color: var(--text);
  font-weight: 600;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  display: block;
}
